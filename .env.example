# ┌──────────────────────────────────────────────────────
# │ Cấu hình production cho V-Affiliate
# └──────────────────────────────────────────────────────

# === Email SMTP (Gmail) ===
# Dùng cho reset password và xác thực email khi đăng ký.
# Bước 1: Bật xác minh 2 bước tại https://myaccount.google.com/security
# Bước 2: Tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# === Base URL ===
# QUAN TRỌNG: Set sang domain thật khi deploy production.
# Email reset password & verify email sẽ chèn link bằng URL này.
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# === CSRF / Origin allowlist ===
# Whitelist origin được phép gửi mutation request (POST/PUT/PATCH/DELETE).
# Mặc định middleware chỉ chấp nhận cùng host với request. Nếu deploy nhiều
# domain (vd. www + apex), liệt kê thêm ở đây, ngăn cách dấu phẩy:
#   https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# === Encryption key cho secret nhạy cảm (TOTP, …) ===
# QUAN TRỌNG: Sinh 32 byte ngẫu nhiên: `openssl rand -hex 32`.
# Backup riêng — nếu mất key, mọi TOTP secret trong DB không decrypt được nữa.
# Format: 64 ký tự hex hoặc 44 ký tự base64.
APP_ENCRYPTION_KEY=

# === Cloudflare Turnstile (captcha) ===
# Lấy keys tại: https://dash.cloudflare.com/?to=/:account/turnstile
# Cấu hình hostname đúng domain production.
# Test keys (luôn pass — chỉ dùng dev):
#   Site:   1x00000000000000000000AA
#   Secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Shopee Affiliate ===
# Affiliate ID của bạn — dùng để gắn vào `mmp_pid` / `utm_source`.
SHOPEE_AFFILIATE_ID=17330180328

# === GoAffiliate API Key (lấy thông tin sản phẩm Shopee) ===
# Đăng ký + thuê key tại https://goaffiliate.online (gói API Basic 10,000 lượt/tháng).
# Khi key được set, mỗi cú gọi sẽ được tính vào quota tài khoản bạn — quan trọng
# khi deploy VPS với IP mới (tránh bị họ chặn vì abuse hoặc tính cho user khác).
GOAFFILIATE_API_KEY=

# === Supabase Postgres ===
# QUAN TRỌNG: Phải dùng Transaction Pooler (port 6543) cho serverless (Vercel).
# Lấy URL tại: Supabase → Project Settings → Database → Connection pooling → Transaction
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# === Admin seed password ===
# Lần đầu boot, tài khoản admin được tạo với password này.
# Nếu để trống → fallback "admin123" + cảnh báo trong log.
# ADMIN_SEED_PASSWORD=

# === Dev / Test flags (KHÔNG bật ở production!) ===
# Tắt rate limit cho test e2e nội bộ.
DISABLE_RATE_LIMIT=
# Tắt verify Turnstile cho test e2e nội bộ.
DISABLE_TURNSTILE=

# === Telegram Bot — alert admin khi có event quan trọng ===
# Setup:
#   1. Mở Telegram → tìm @BotFather → /newbot → đặt tên → nhận TOKEN
#   2. Mở Telegram → tìm @userinfobot → /start → nhận CHAT_ID của bạn
#   3. Mở chat với bot mới → /start (để bot có thể nhắn cho bạn)
#   4. Set 2 env dưới
# Nếu để trống → app vẫn chạy bình thường, chỉ skip notification.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
